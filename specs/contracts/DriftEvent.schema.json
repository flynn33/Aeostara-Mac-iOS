{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DriftEvent",
  "description": "A single detected drift between observed and desired state",
  "type": "object",
  "properties": {
    "keyPath": {
      "type": "string",
      "description": "Dot-path to the drifted key"
    },
    "type": {
      "type": "string",
      "enum": ["ValueChanged", "KeyAdded", "KeyRemoved"],
      "description": "The kind of drift detected"
    },
    "observedValue": {
      "description": "Current value in observed state (null if KeyAdded)"
    },
    "desiredValue": {
      "description": "Expected value in desired state (null if KeyRemoved)"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the drift"
    }
  },
  "required": ["keyPath", "type", "description"],
  "additionalProperties": false
}
