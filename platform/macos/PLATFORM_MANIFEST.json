{
  "platform": "macos",
  "displayName": "Aeostara for macOS",
  "status": "implemented",
  "version": "0.1.0",
  "toolchain": {
    "compiler": "Apple Clang",
    "buildSystem": "CMake 3.28+ with Ninja",
    "minimumTarget": "macOS 13.0",
    "standard": "C++20"
  },
  "implementation": {
    "language": "C++20",
    "testFramework": "Catch2",
    "dependencies": ["nlohmann/json", "catch2"]
  },
  "shell": {
    "type": "CLI",
    "commands": ["validate", "diff", "heal"],
    "futureGUI": "AppKit or SwiftUI (deferred)"
  },
  "ci": {
    "buildWorkflow": "macos-build-test.yml",
    "ciProven": true,
    "cliSmokeTested": true
  },
  "compliance": {
    "forsettiBridge": "stub",
    "configFormat": "JSON-only",
    "noPython": true,
    "noYAML": true
  },
  "acceptanceScenarios": [
    "valid config / no drift",
    "invalid config / parse error",
    "policy blocked",
    "successful repair",
    "forced rollback"
  ]
}
