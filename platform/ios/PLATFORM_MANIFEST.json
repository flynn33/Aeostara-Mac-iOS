{
  "platform": "ios",
  "displayName": "Aeostara for iOS",
  "status": "source-complete, build-unverified",
  "version": "0.1.0",
  "toolchain": {
    "ide": "Xcode 15+",
    "minimumTarget": "iOS 16.0",
    "swift": "5.9+"
  },
  "implementation": {
    "language": "Swift (pure — no C++, no Objective-C++)",
    "uiFramework": "SwiftUI",
    "buildSystem": "SwiftPM (Package.swift)",
    "testFramework": "XCTest, XCUITest",
    "dependencies": []
  },
  "modules": {
    "domain": "AeostaraDomain (Sources/AeostaraDomain/) — 14 Swift files",
    "services": "AeostaraServices (Sources/AeostaraServices/) — 3 Swift files",
    "app": "AeostaraApp (Sources/AeostaraApp/) — 3 Swift files",
    "tests": "AeostaraTests (Tests/AeostaraTests/) — 12 Swift files + fixtures",
    "uiTests": "AeostaraUITests (Tests/AeostaraUITests/) — 1 Swift file"
  },
  "shell": {
    "type": "SwiftUI app",
    "cli": false,
    "features": [
      "File import via document picker",
      "Sandbox-local file staging",
      "Validate / Diff / Heal operations",
      "Audit trail viewer",
      "Backup in app container"
    ]
  },
  "ci": {
    "buildWorkflow": "ios-build-test.yml",
    "testTargets": ["AeostaraTests", "AeostaraUITests"]
  },
  "compliance": {
    "nativeOnly": true,
    "configFormat": "JSON-only",
    "noPython": true,
    "noYAML": true,
    "noCpp": true,
    "noObjCpp": true,
    "noCMake": true,
    "noVcpkg": true,
    "noCatch2": true,
    "noNlohmannJson": true,
    "sandboxed": true,
    "forsettiCompliant": true,
    "allClassesFinal": true,
    "foundationOnly": true
  },
  "quarantine": {
    "path": "_quarantine/",
    "contents": "Non-compliant reference artifacts from pre-remediation C++20/Obj-C++ implementation",
    "shipped": false
  }
}
